node_modules/
dist/
# agent-runner ships as a JS GitHub Action — its bundled dist/ MUST be committed
# (GitHub runs action.yml `main: dist/index.js` as-is, with no build step).
!agent-runner/dist/
!agent-runner/dist/**
build/
.next/
out/
coverage/
*.tsbuildinfo
.env
.env.local
.DS_Store
.idea/
.turbo/
.pnpm-store/
*.log
.devdigest/cache/
clones/
playwright-report/
test-results/

# emdash worktree config (local)
.emdash.json

# pr-self-review runtime report (regenerated per branch diff; not committed).
# The waivers file IS committed — it records intentional, reviewed exceptions.
.claude/pr-self-review-report.json
